{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "custom/music"
  ],
  "modules-right": [
    "pulseaudio",
    "backlight",
    "battery",
    "clock",
    "tray",
    "custom/lock",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "disable-scroll": true,
    "sort-by-name": true,
    "format": " {icon} ",
    "format-icons": {
      "default": "оЃі"
    }
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "custom/music": {
    "format": "пАБ  {}",
    "escape": true,
    "interval": 5,
    "tooltip": false,
    "exec": "playerctl metadata --format='{{ title }}'",
    "on-click": "playerctl play-pause",
    "max-length": 50
  },
  "clock": {
    "timezone": "Europe/Bucharest",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "пЧђ {:%d/%m/%Y}",
    "format": "пЩП {:%H:%M}"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": [
      "оОН",
      "оПУ",
      "оПС",
      "оПП",
      "оПО",
      "оПН",
      "оПК",
      "оПИ",
      "оОЫ"
    ]
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-charging": "пЦГ",
    "format-plugged": "пЦГ",
    "format-alt": "{icon}",
    "format-icons": [
      "пЦВ",
      "пХє",
      "пХЇ",
      "пХї",
      "пХЉ",
      "пХљ",
      "пХљ",
      "пХЊ",
      "пХњ",
      "пЦА",
      "пЦБ",
      "пХЄ"
    ]
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "пС¶",
    "format-icons": {
      "default": [
        "пА¶",
        "пАІ",
        "пА® "
      ]
    },
    "on-click": "pavucontrol"
  },
  "custom/lock": {
    "tooltip": false,
    "on-click": "sh -c '(sleep 0.5s; swaylock --image $HOME/.config/hypr/wallpaper.png)' & disown",
    "format": "пА£"
  },
  "custom/power": {
    "tooltip": false,
    "on-click": "wlogout &",
    "format": "п§§"
  }
}
